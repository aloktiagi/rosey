# Required for any deployment
ANTHROPIC_API_KEY=sk-ant-...
MEMORY_ROOT=./memories
SCHEDULER_TZ=America/Los_Angeles

# Telegram — get token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAEh...
# Optional: leave blank for polling mode (self-host); set for webhook mode on Fly etc.
# TELEGRAM_WEBHOOK_URL=https://your-bot.fly.dev

# Voice notes via OpenAI Whisper (optional)
OPENAI_API_KEY=sk-...

# Optional text PII redaction before model calls
# ROSEY_REDACTION=on
# ROSEY_PII_VAULT=./pii/vault.json

# SaaS router only (most self-hosters can ignore)
# ROSEY_INTERNAL_TOKEN=generate-with-python-secrets-token_urlsafe-32
# TELEGRAM_WEBHOOK_SECRET=generate-with-python-secrets-token_urlsafe-32
# TELEGRAM_BOT_USERNAME=your_bot_username
# ROSEY_OPERATOR_TELEGRAM_ID=your_chat_id_for_feedback_forwarding
# FLY_API_TOKEN=...   # so the router can shell out to flyctl
